# ============================================================
# litellm-stack environment variables
# Copy to .env and fill in actual values
# ============================================================

# LiteLLM admin key (must start with sk-)
# Generate with: echo "sk-$(openssl rand -hex 24)"
LITELLM_MASTER_KEY=sk-change-me
LITELLM_PORT=4000

# --- Local LLM endpoints (must include /v1) ---
# llama-swap / llama-server on your GPU host
# Example: https://<server-ip>:8443/v1
LLAMA_SERVER_URL=
# llama-server on portable host (leave empty if not available)
# Example: https://<server-ip>:8443/v1
PORTABLE_LLM_SERVER_URL=

# --- Local model names (must match llama-swap / llama-server model names) ---
# Prefix with "openai/" for LiteLLM's OpenAI-compatible routing
REASONER_LOCAL_MODEL=openai/gpt-oss-120b-MXFP4
JUDGE_LOCAL_MODEL=openai/qwen2.5-7b-instruct

# --- Cloud API keys (optional, for fallback) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
