# ============================================================
# litellm-stack environment variables
# Copy to .env and fill in actual values
# ============================================================

# LiteLLM admin key (must start with sk-)
# Generate with: echo "sk-$(openssl rand -hex 24)"
LITELLM_MASTER_KEY=sk-change-me
LITELLM_PORT=4000

# --- Local LLM endpoints (must include /v1) ---
# llama-swap / llama-server on your GPU host
# Example: https://<server-ip>:8443/v1
LLAMA_SERVER_URL=
# llama-server on portable host (leave empty if not available)
# Example: https://<server-ip>:8443/v1
PORTABLE_LLM_SERVER_URL=

# --- TLS CA certificate (for self-signed certs on llama-server) ---
# Path to mkcert rootCA.pem on the Docker host
CA_CERT_PATH=

# --- Local model names (must match llama-swap / llama-server model keys) ---
# Prefix with "openai/" for LiteLLM's OpenAI-compatible routing
DIRECT_LOCAL_MODEL=openai/gpt-oss-120b-MXFP4
REASONER_LOCAL_MODEL=openai/gpt-oss-20b-MXFP4
JUDGE_LOCAL_MODEL=openai/Qwen2.5-7B-Instruct-Q4_K_M

# --- Cloud fallback models ---
REASONER_CLOUD_MODEL=openai/gpt-4o
JUDGE_CLOUD_MODEL=openai/gpt-4o-mini

# --- Cloud API key (optional, for fallback) ---
CLOUD_API_KEY=
